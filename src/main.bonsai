                      <cv:Y>539</cv:Y>
                    </cv:Point>
                    <cv:Point>
                      <cv:X>9</cv:X>
                      <cv:Y>277</cv:Y>
                    </cv:Point>
                  </cv:ArrayOfPoint>
                </cv:Regions>
                <cv:MaskType>ToZero</cv:MaskType>
                <cv:FillValue>
                  <cv:Val0>150</cv:Val0>
                  <cv:Val1>150</cv:Val1>
                  <cv:Val2>150</cv:Val2>
                  <cv:Val3>150</cv:Val3>
                </cv:FillValue>
              </Combinator>
            </Expression>
            <Expression xsi:type="Combinator">
              <Combinator xsi:type="cv:Threshold">
                <cv:ThresholdValue>11</cv:ThresholdValue>
                <cv:MaxValue>255</cv:MaxValue>
                <cv:ThresholdType>BinaryInv</cv:ThresholdType>
              </Combinator>
            </Expression>
            <Expression xsi:type="rx:PublishSubject">
              <Name>ThresholdFeed</Name>
            </Expression>
            <Expression xsi:type="Combinator">
