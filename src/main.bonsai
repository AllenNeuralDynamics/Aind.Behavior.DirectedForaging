                      <cv:Y>134</cv:Y>
                    </cv:Point>
                    <cv:Point>
                      <cv:X>323</cv:X>
                      <cv:Y>76</cv:Y>
                    </cv:Point>
                    <cv:Point>
                      <cv:X>615</cv:X>
                      <cv:Y>70</cv:Y>
