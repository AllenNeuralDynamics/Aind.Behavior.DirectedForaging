      "properties": {
        "family": {
          "const": "Poisson",
          "default": "Poisson",
          "title": "Family",
          "type": "string"
        },
        "rate": {
          "default": 1,
          "description": "Rate parameter of the Poisson process that generates the distribution",
          "minimum": 0,
