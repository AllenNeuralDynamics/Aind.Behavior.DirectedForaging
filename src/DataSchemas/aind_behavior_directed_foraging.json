              "$ref": "#/$defs/BaseModel"
            },
            {
              "type": "null"
            }
          ]
        },
        "who_am_i": {
          "const": 1409,
          "default": 1409,
          "title": "Who Am I",
          "type": "integer"
        },
        "serial_number": {
          "default": null,
          "description": "Device serial number",
          "oneOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "title": "Serial Number"
        },
        "port_name": {
          "description": "Device port name",
          "title": "Port Name",
          "type": "string"
        },
        "enable_valve_leds": {
          "title": "Enable Valve Leds",
          "type": "boolean"
        },
        "minimum_poke_time": {
          "default": 0.1,
          "title": "Minimum Poke Time",
          "type": "number"
        },
        "minimum_odor_delivery_time": {
          "default": 0.5,
          "title": "Minimum Odor Delivery Time",
          "type": "number"
        },
        "final_valve_energized_time": {
          "default": 0.11,
          "title": "Final Valve Energized Time",
          "type": "number"
        },
        "vacuum_setup_time": {
          "default": 0.01,
          "title": "Vacuum Setup Time",
