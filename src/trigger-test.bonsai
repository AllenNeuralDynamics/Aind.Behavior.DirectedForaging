      <Expression xsi:type="Disable">
        <Builder xsi:type="scr:ExpressionTransform">
          <scr:Name>EuclideanDistance</scr:Name>
          <scr:Expression>Math.Sqrt(Math.Pow(it.Item2.X - it.Item1.X, 2) + Math.Pow(it.Item2.Y - it.Item1.Y, 2))</scr:Expression>
        </Builder>
      </Expression>
